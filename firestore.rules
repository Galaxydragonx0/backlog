rules_version = '2';

// Backlog security rules: every document lives under users/{uid}/... and is
// readable/writable ONLY by that signed-in user. Nothing is public.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
